{
  "name": "sidenote",
  "version": "1.0.0",
  "description": "A productivity sidebar note-taking app for Mac",
  "main": "main.js",
  "build": {
    "appId": "com.sidenote.app",
    "productName": "SideNote",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ]
  },
  "scripts": {
    "dist": "electron-builder --mac",
    "start": "electron .",
    "dev": "electron . --dev"
  },
  "keywords": [
    "notes",
    "productivity",
    "sidebar",
    "markdown"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.1.0",
    "marked": "^9.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}